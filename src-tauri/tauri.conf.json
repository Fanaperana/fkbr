{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kbr",
  "version": "0.1.0",
  "identifier": "com.kbr.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "kbr",
        "label": "main",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "backgroundColor": null
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
