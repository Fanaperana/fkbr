{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FKBR",
  "version": "1.0.0",
  "identifier": "com.fanaperana.fkbr",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "fkbr",
        "label": "main",
        "create": true,
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "backgroundColor": null,
        "resizable": false,
        "fullscreen": true,
        "hiddenTitle": true,
        "focus": true,
        "shadow": false,
        "skipTaskbar": true,
        "windowEffects": null,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
